# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Environment / secrets ──────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Alembic ────────────────────────────────────────────────────────────────────
# Keep migrations/versions tracked — only ignore local alembic overrides
alembic.ini.local

# ── Pytest / coverage ──────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ── Node / frontend ────────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/build/
frontend/.env
frontend/.env.*
!frontend/.env.example
*.tsbuildinfo

# ── macOS ──────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDE ────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
